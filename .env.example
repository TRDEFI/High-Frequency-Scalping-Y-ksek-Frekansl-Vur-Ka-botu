# Bybit API Credentials (Testnet recommended for development)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Bot Settings
TRADING_SYMBOL=BTCUSDT
IS_TESTNET=True
CATEGORY=linear

# Position Sizing
POSITION_SIZE_USDT=200
LEVERAGE=5
MAX_OPEN_POSITIONS=8

# Risk Management
ATR_SL_MULTIPLIER=0.4
RISK_REWARD_RATIO=1.2
DAILY_LOSS_LIMIT_USDT=100
MAX_CONSECUTIVE_LOSSES=5
POST_LOSS_COOLDOWN_SECONDS=180
CONSECUTIVE_LOSS_PAUSE=300
TRADE_COOLDOWN_SECONDS=30

# Volatility Regime
VOL_LOW_THRESHOLD=0.003
VOL_HIGH_THRESHOLD=0.015

# Adaptive Position Sizing
ADAPTIVE_SIZING_ENABLED=True
ADAPTIVE_LOOKBACK_TRADES=5
MIN_POSITION_SIZE=100
MAX_POSITION_SIZE=250

# Multi-Timeframe
PRIMARY_TIMEFRAME=1
CONFIRMATION_TIMEFRAME=3

# Order Flow
ORDER_FLOW_ENABLED=True
AGGRESSIVE_RATIO_THRESHOLD=1.3
LARGE_TRADE_PERCENTILE=95

# Strategy Thresholds
OBI_THRESHOLD=0.2
STOCH_RSI_OVERSOLD=25
STOCH_RSI_OVERBOUGHT=75
